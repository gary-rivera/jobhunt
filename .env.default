PORT=3000
DATABASE_URL=""
OLLAMA_HOST=""
OLLAMA_PORT=""
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
OLLAMA_CHAT_MODEL="llama3.1:8b"
OLLAMA_EXTRACTION_MODEL="llama3.1:8b"
OLLAMA_EXTRACTION_NUM_CTX=8192

APP_TZ="America/New_York"
DEFAULT_USER_ALIAS="dingle"
WTTJ_CREDS_CACHE_PATH="./data/wttj-creds.json"
WTTJ_INDEX="wk_cms_jobs_production"
RUN_ORPHAN_TIMEOUT_MIN=30

# Comma-separated, case-insensitive substrings matched against a listing's
# location. A listing is saved only if its location contains one of these
# substrings. Default: "san francisco,remote".
LOCATION_ALLOWLIST="san francisco,remote"

# LinkedIn adapter
LINKEDIN_HEADLESS="true"
LINKEDIN_NAV_TIMEOUT_MS="30000"
LINKEDIN_DETAIL_DELAY_MS="1500"
